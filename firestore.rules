rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMember(circleId) {
      return signedIn()
        && exists(/databases/$(database)/documents/circles/$(circleId)/members/$(request.auth.uid));
    }

    match /circles/{circleId} {
      allow read: if isMember(circleId);
      allow create: if signedIn();
      allow update: if signedIn();

      match /members/{userId} {
        allow read: if isMember(circleId);
        allow create, update: if signedIn() && request.auth.uid == userId;
      }

      match /dramas/{dramaId} {
        allow read: if isMember(circleId);
        allow create, update: if isMember(circleId);
      }

      match /reviews/{reviewId} {
        allow read: if isMember(circleId);
        allow create: if isMember(circleId)
          && request.resource.data.userId == request.auth.uid;
        allow update: if isMember(circleId)
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == request.auth.uid;
        allow delete: if false;
      }

      match /comparisons/{comparisonId} {
        allow read: if isMember(circleId);
        allow create: if isMember(circleId)
          && request.resource.data.userId == request.auth.uid;
        allow update: if isMember(circleId)
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == request.auth.uid;
        allow delete: if false;
      }

      match /activities/{activityId} {
        allow read: if isMember(circleId);
        allow create: if isMember(circleId)
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }
  }
}
